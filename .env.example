# SECRET_KEY: Genereer met `python3 -c "import secrets; print(secrets.token_hex(32))"`
# VERPLICHT in productie — zonder wordt de app gestart met een hardcoded fallback.
SECRET_KEY=vervang-dit-met-een-veilige-sleutel-in-productie

# Database URL (default: SQLite lokaal)
# Voor productie: zet op PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./patienten.db

# JWT instellingen
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Lock timeout (minuten)
LOCK_TIMEOUT_MINUTES=5
LOCK_HEARTBEAT_SECONDS=30
